# .gitignore

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Modelo (não versionar modelos grandes)
models/*.gguf
models/adapters/*.gguf
!models/.gitkeep

# Dados sensíveis
data/lessons/curated/*.jsonl
!data/lessons/curated/.gitkeep

# Relatórios
reports/
!reports/.gitkeep

# Ambiente
.env
.env.local
.env.production
.env.*.encrypted

# OS
.DS_Store
Thumbs.db
